// This file defines the shape of your database.
// Each "model" = a table. Each field inside = a column.
// When you change this file, run "npx prisma db push" to apply the changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role defines the allowed values for the `role` field on User.
// An enum is like a fixed list of options — the database rejects anything not on it.
enum Role {
  OWNER
  SITTER
  BOTH
}

// User maps to a "users" table in PostgreSQL.
// Each person who signs up gets one row in this table.
model User {
  // id: auto-generated unique identifier (cuid = collision-resistant unique id)
  id        String   @id @default(cuid())

  // clerkId: the ID Clerk assigns to this user in THEIR system.
  // @unique means no two rows can have the same clerkId.
  clerkId   String   @unique

  // email must also be unique across all users
  email     String   @unique

  firstName String
  lastName  String

  // The ? means this field is optional — can be null
  avatarUrl String?

  // role defaults to OWNER when a new user is created
  role      Role     @default(OWNER)

  // bio is a short description the user writes about themselves
  bio       String?

  // hasCompletedOnboarding tracks if the user has explicitly chosen their role.
  // role defaults to OWNER so we can't use role alone to know this.
  // Once the user picks a role on /onboarding, this is set to true.
  hasCompletedOnboarding Boolean @default(false)

  // pets: a user can own many pets (one-to-many relation)
  pets      Pet[]

  // Prisma manages these automatically
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Pet maps to a "pets" table in PostgreSQL.
// Each pet belongs to exactly one user (the owner).
model Pet {
  // id: auto-generated unique identifier
  id       String  @id @default(cuid())

  // name is required — every pet must have one
  name     String

  // species is required — chosen from a predefined list on the frontend
  // Stored as a plain String (not an enum) so adding new species doesn't require a DB migration
  species  String

  // All remaining fields are optional (? = can be null)
  breed    String?
  age      Float?   // in years — Float allows e.g. 2.5 (two and a half years old)
  weight   Float?   // in pounds
  notes    String?  // free-text care instructions for sitters
  imageUrl String?  // placeholder for future Cloudinary photo upload

  // Relation — every pet belongs to exactly one user.
  // userId stores our internal User.id (the cuid), NOT the Clerk ID.
  // This is the standard foreign key pattern in relational databases.
  userId   String
  owner    User     @relation(fields: [userId], references: [id])

  // Prisma manages these automatically
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
