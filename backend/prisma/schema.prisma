// This file defines the shape of your database.
// Each "model" = a table. Each field inside = a column.
// When you change this file, run "npx prisma db push" to apply the changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role defines the allowed values for the `role` field on User.
// An enum is like a fixed list of options — the database rejects anything not on it.
enum Role {
  OWNER
  SITTER
  BOTH
}

// BookingStatus tracks where a booking is in its lifecycle.
enum BookingStatus {
  PENDING      // owner submitted; waiting for sitter to respond
  CONFIRMED    // sitter accepted
  CANCELLED    // either party cancelled
  COMPLETED    // stay is finished
}

// User maps to a "users" table in PostgreSQL.
// Each person who signs up gets one row in this table.
model User {
  // id: auto-generated unique identifier (cuid = collision-resistant unique id)
  id        String   @id @default(cuid())

  // clerkId: the ID Clerk assigns to this user in THEIR system.
  // @unique means no two rows can have the same clerkId.
  clerkId   String   @unique

  // email must also be unique across all users
  email     String   @unique

  firstName String
  lastName  String

  // The ? means this field is optional — can be null
  avatarUrl String?

  // role defaults to OWNER when a new user is created
  role      Role     @default(OWNER)

  // bio is a short description the user writes about themselves
  bio       String?

  // hasCompletedOnboarding tracks if the user has explicitly chosen their role.
  // role defaults to OWNER so we can't use role alone to know this.
  // Once the user picks a role on /onboarding, this is set to true.
  hasCompletedOnboarding Boolean @default(false)

  // pets: a user can own many pets (one-to-many relation)
  pets      Pet[]

  // sitterProfile: if the user is a sitter, they have one listing (one-to-one relation)
  sitterProfile SitterProfile?

  // bookings made by this user as a pet owner
  ownerBookings  Booking[]  @relation("OwnerBookings")

  // messages sent by this user
  messagesSent   Message[]  @relation("MessagesSent")

  // reviews written by this user (as a pet owner reviewing a sitter)
  reviewsWritten Review[]   @relation("ReviewsWritten")

  // Prisma manages these automatically
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Pet maps to a "pets" table in PostgreSQL.
// Each pet belongs to exactly one user (the owner).
model Pet {
  // id: auto-generated unique identifier
  id       String  @id @default(cuid())

  // name is required — every pet must have one
  name     String

  // species is required — chosen from a predefined list on the frontend
  // Stored as a plain String (not an enum) so adding new species doesn't require a DB migration
  species  String

  // All remaining fields are optional (? = can be null)
  breed    String?
  age      Float?   // in years — Float allows e.g. 2.5 (two and a half years old)
  weight   Float?   // in pounds
  notes    String?  // free-text care instructions for sitters
  imageUrl String?  // placeholder for future Cloudinary photo upload

  // Relation — every pet belongs to exactly one user.
  // userId stores our internal User.id (the cuid), NOT the Clerk ID.
  // This is the standard foreign key pattern in relational databases.
  userId   String
  owner    User     @relation(fields: [userId], references: [id])

  // bookings that include this pet
  bookings Booking[]

  // Prisma manages these automatically
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// SitterProfile maps to a "sitter_profiles" table.
// Only users with role SITTER or BOTH will have one of these.
// One-to-one with User (@unique on userId).
model SitterProfile {
  id              String   @id @default(cuid())

  // One-to-one relation with User
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])

  // rate: per-night rate in USD (required when creating a listing)
  rate            Float

  // services: array of service names the sitter offers
  // Stored as a PostgreSQL TEXT[] array — no join table needed for a simple list
  services        String[]

  // Location fields — all optional
  city            String?
  state           String?  // 2-letter abbreviation, e.g. "CA"
  zipCode         String?

  // isAvailable: false = sitter is taking a break and won't appear in search
  isAvailable     Boolean  @default(true)

  // Optional context for owners
  yearsExperience Int?

  // bookings received by this sitter
  bookings        Booking[]

  // reviews left for this sitter by owners
  reviews         Review[]

  // Prisma manages these automatically
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Booking maps to a "bookings" table.
// Created when a pet owner requests a stay with a sitter.
model Booking {
  id              String        @id @default(cuid())

  // Owner side — the pet owner who made this request
  ownerId         String
  owner           User          @relation("OwnerBookings", fields: [ownerId], references: [id])

  // Sitter side — linked to the SitterProfile (not the User directly)
  sitterProfileId String
  sitterProfile   SitterProfile @relation(fields: [sitterProfileId], references: [id])

  // Which pet is being cared for
  petId           String
  pet             Pet           @relation(fields: [petId], references: [id])

  // Stay details
  service         String        // one of the 5 service types
  startDate       DateTime
  endDate         DateTime
  totalPrice      Float         // rate × nights, computed at booking creation time
  message         String?       // optional note from owner to sitter

  status          BookingStatus @default(PENDING)

  // review left by the owner after the stay (one-to-one, optional)
  review          Review?

  // messages exchanged between owner and sitter for this booking
  messages        Message[]

  // Prisma manages these automatically
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Message maps to a "messages" table.
// One message thread per booking — both owner and sitter can send messages.
// Delivered in real-time via Socket.io; initial load uses REST GET /api/messages/:bookingId.
model Message {
  id        String   @id @default(cuid())

  // Which booking this message belongs to
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])

  // Who sent this message
  senderId  String
  sender    User     @relation("MessagesSent", fields: [senderId], references: [id])

  // The message content
  text      String

  createdAt DateTime @default(now())
}

// Review maps to a "reviews" table.
// Created by a pet owner after a COMPLETED booking to rate and review the sitter.
// One review per booking (@unique on bookingId).
model Review {
  id              String        @id @default(cuid())

  // One review per booking
  bookingId       String        @unique
  booking         Booking       @relation(fields: [bookingId], references: [id])

  // The pet owner who wrote this review
  authorId        String
  author          User          @relation("ReviewsWritten", fields: [authorId], references: [id])

  // The sitter being reviewed
  sitterProfileId String
  sitterProfile   SitterProfile @relation(fields: [sitterProfileId], references: [id])

  // Content
  rating          Int           // 1–5 stars
  text            String?       // optional written review

  // Prisma manages this automatically
  createdAt       DateTime @default(now())
}
